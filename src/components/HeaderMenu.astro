---
import AuthModal from "@components/AuthModal";

const url = Astro.url.pathname;
const currentLevel = url;
---

<header class="bg-gray-900 text-white fixed top-0 left-0 w-screen">
  <nav class="flex flex-wrap items-center justify-between px-6 py-4">
    <a href="/" class="text-2xl font-bold">Ejercicios de lógica programacion</a>
    <ul class="flex items-center gap-x-4">
      <li>
        <a
          href="/"
          class={`text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md ${
            currentLevel === "/" ? "border-b-4 border-blue-500 text-white" : ""
          }`}>Inicio</a
        >
      </li>
      <li>
        <a
          href="/about"
          class={`text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md ${
            currentLevel === "/about"
              ? "border-b-4 border-blue-500 text-white"
              : ""
          }`}>Acerca de</a
        >
      </li>
      {
        [1, 2, 3].map((level) => (
          <li>
            <a
              href={`/level/${level}`}
              class={`text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md ${
                currentLevel === `/level/${level}`
                  ? "border-b-4 border-blue-500 text-white"
                  : ""
              }`}
            >
              Nivel {level}
            </a>
          </li>
        ))
      }
      <li>
        <a
          href="/levels"
          class={`text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md ${
            currentLevel === "/levels"
              ? "border-b-4 border-blue-500 text-white"
              : ""
          }`}>Niveles Completos</a
        >
      </li>
    </ul>

    <div class="mt-4 sm:mt-0">
      <AuthModal client:idle />
    </div>
  </nav>
</header>
